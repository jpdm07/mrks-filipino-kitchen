# Production / Vercel: Neon, Supabase, or Vercel Postgres (connection pooling URL recommended).
# Local: same URL as your dev branch, or run Postgres in Docker and paste its URL here.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"
# Prisma uses engineType = "binary" in schema.prisma (child process) for broad Windows compatibility.
TWILIO_ACCOUNT_SID="your_twilio_sid"
TWILIO_AUTH_TOKEN="your_twilio_token"
TWILIO_FROM_PHONE="+1XXXXXXXXXX"
OWNER_PHONE="+19797033827"
GOOGLE_SHEETS_WEBHOOK_URL="paste_your_apps_script_web_app_url_here"

# Google Calendar — service account JWT; share "Mr. K's Kitchen Pickups" with the SA email.
# Do not use a personal calendar ID here. GOOGLE_ACCOUNT_EMAIL is reference only (not impersonation in app).
GOOGLE_SERVICE_ACCOUNT_EMAIL=""
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n"
GOOGLE_ACCOUNT_EMAIL="jpdm015@gmail.com"
GOOGLE_CALENDAR_ID=""

# Admin finances: receipt OCR (server-side only; never expose to browser).
ANTHROPIC_API_KEY=""
EMAIL_USER="jpdm07@yahoo.com"
EMAIL_PASSWORD="your_yahoo_app_password"
ADMIN_USERNAME="mrk_admin"
ADMIN_PASSWORD="choose_a_strong_password_here"
# Must match your live domain (business cards / QR codes / email links). Do not use www unless that is your canonical host.
NEXT_PUBLIC_SITE_URL="https://mrkskitchen.com"
# Venmo handle shown on checkout (e.g. @YourVenmoName)
NEXT_PUBLIC_VENMO_HANDLE="@jpdm07"

# Optional: full-bleed hero + Open Graph image (defaults to a sharp Unsplash photo).
# Use your own wide photo for best quality, e.g. /images/lumpia.jpg (export ~1920–2400px wide).
# NEXT_PUBLIC_HERO_FULLBLEED_IMAGE="/images/lumpia.jpg"
# Optional: culture/FAQ page decorative corner (defaults to /images/pancit.jpg).
# NEXT_PUBLIC_CULTURE_DECOR_IMAGE="https://images.unsplash.com/photo-…"

# Optional: background OPM playlist (HTTPS URLs to your licensed MP3s).
# If unset, the site uses /public/audio/kailan.mp3, harana.mp3, simpleng-tao.mp3
# NEXT_PUBLIC_OPM_KAILAN_URL="https://example.com/kailan.mp3"
# NEXT_PUBLIC_OPM_HARANA_URL="https://example.com/harana.mp3"
# NEXT_PUBLIC_OPM_SIMPLENG_TAO_URL="https://example.com/simpleng-tao.mp3"
