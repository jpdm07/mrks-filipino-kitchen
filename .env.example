# Production / Vercel: Neon, Supabase, or Vercel Postgres (connection pooling URL recommended).
# Local: same URL as your dev branch, or run Postgres in Docker and paste its URL here.
# Local dev: use the same hosted Postgres URL as production (e.g. Neon), not localhost, unless you run Postgres locally.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"
# After copying Vercel Production DATABASE_URL here (often in .env.local), run:
#   npm run db:migrate
# That script loads .env then .env.local so Prisma applies migrations to the URL you pasted (plain `npx prisma migrate deploy` only auto-loads `.env`).
# Vercel: set RUN_MIGRATE_ON_VERCEL=1 if you want `prisma migrate deploy` during each production build (optional).
# Otherwise run `npm run db:migrate` locally against production DATABASE_URL when you ship schema changes.
# Prisma uses engineType = "binary" in schema.prisma (child process) for broad Windows compatibility.
TWILIO_ACCOUNT_SID="your_twilio_sid"
TWILIO_AUTH_TOKEN="your_twilio_token"
TWILIO_FROM_PHONE="+1XXXXXXXXXX"
OWNER_PHONE="+19797033827"
GOOGLE_SHEETS_WEBHOOK_URL="paste_your_apps_script_web_app_url_here"

# Google Calendar — service account JWT; share "Mr. K's Kitchen Pickups" with the SA email.
# Do not use a personal calendar ID here. GOOGLE_ACCOUNT_EMAIL is reference only (not impersonation in app).
GOOGLE_SERVICE_ACCOUNT_EMAIL=""
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n"
GOOGLE_ACCOUNT_EMAIL="jpdm015@gmail.com"
GOOGLE_CALENDAR_ID=""

# Pickup calendar: auto-pull Google → DB on public /api/availability (throttled). Set false to disable locally.
# GOOGLE_AVAILABILITY_AUTO_SYNC=false
# Minutes between pulls per server instance (default 5; max 120).
# GOOGLE_AVAILABILITY_SYNC_MINUTES=5

# Optional: Vercel Cron bearer. If unset, scheduled jobs still run on Vercel via x-vercel-cron / vercel-cron user-agent.
# CRON_SECRET=""

# Admin finances: receipt OCR (server-side only; never expose to browser).
ANTHROPIC_API_KEY=""
# Order emails, receipts, newsletter — you do NOT need Resend. SMTP below is enough:
#   EMAIL_USER + EMAIL_PASSWORD (Yahoo/Gmail need an app password, not your normal login).
#   If Gmail only lets you send via a personal login (e.g. jpdm015@gmail.com), use that
#   for EMAIL_USER and put the kitchen inbox in EMAIL_REPLY_TO + OWNER_ORDER_EMAIL.
#   Optional: in Google → Settings → “Send mail as”, add mrksfilipinokitchen@gmail.com
#   to the jpdm account, then set EMAIL_FROM to the kitchen address so “From” matches the brand.
# Optional later: Resend (omit RESEND_API_KEY until then; if you set it, it takes priority over SMTP).
# RESEND_API_KEY="re_..."
# RESEND_FROM_EMAIL="Mr. K's Filipino Kitchen <orders@yourdomain.com>"
EMAIL_USER="jpdm015@gmail.com"
EMAIL_PASSWORD="your_gmail_app_password"
# Gmail: use an app password, not your normal login.
# EMAIL_SMTP_HOST="smtp.gmail.com"
# EMAIL_SMTP_PORT="587"
# EMAIL_SMTP_SECURE="false"
# Where customer “Reply” should go (also used in email footers). Kitchen inbox:
EMAIL_REPLY_TO="mrksfilipinokitchen@gmail.com"
# Optional: visible From when it differs from EMAIL_USER (requires Gmail “Send mail as” verified).
# EMAIL_FROM="mrksfilipinokitchen@gmail.com"
# EMAIL_FROM_NAME="Mr. K's Filipino Kitchen"
# Optional: logo image at the top of branded emails (full https URL, or a path on this site e.g. /images/email-logo.png).
# EMAIL_BRAND_IMAGE_URL="https://mrkskitchen.com/images/email-logo.png"
# NEXT_PUBLIC_EMAIL_LOGO_URL="/images/email-logo.png"
# Optional: show “test / demo order” on checkout (also set server-side below). Turn off in production if you don’t need it.
# NEXT_PUBLIC_ALLOW_DEMO_CHECKOUT="true"
# Server must allow demo flag from checkout JSON (pair with NEXT_PUBLIC_ above).
# ALLOW_DEMO_ORDERS_AT_CHECKOUT="true"
# New-order notification recipient (defaults to EMAIL_USER if unset). Use kitchen inbox:
# OWNER_ORDER_EMAIL="mrksfilipinokitchen@gmail.com"
# Optional: blind-copy customer receipt emails from admin (Resend/SMTP). Does not change the “To” address.
# RECEIPT_EMAIL_BCC="you@yourdomain.com"
ADMIN_USERNAME="mrk_admin"
ADMIN_PASSWORD="choose_a_strong_password_here"
# Optional: HMAC secret for admin session cookies (if unset, ADMIN_PASSWORD is used). Set on Vercel if you change passwords often.
# ADMIN_SESSION_SECRET="long-random-string"

# Must match your live domain (business cards / QR codes / email links). Do not use www unless that is your canonical host.
NEXT_PUBLIC_SITE_URL="https://mrkskitchen.com"
# Optional: Facebook Page URL (https, must be facebook.com or fb.com). If unset, uses profile.php?id=… for reliable mobile/WebView opens.
# NEXT_PUBLIC_FACEBOOK_URL="https://www.facebook.com/profile.php?id=61587453610719"
# Venmo handle shown on checkout (e.g. @YourVenmoName)
NEXT_PUBLIC_VENMO_HANDLE="@jpdm07"
# Cash App cashtag on checkout (include $)
NEXT_PUBLIC_CASHAPP_CASHTAG="$MrKsFilipinoKitchen"

# Optional: full-bleed hero (defaults to a lumpia-style spring roll plate on Unsplash).
# Use your own wide photo for best quality, e.g. /images/lumpia.jpg (export ~1920–2400px wide).
# NEXT_PUBLIC_HERO_FULLBLEED_IMAGE="/images/lumpia.jpg"
# Optional: link-preview image only (Facebook, iMessage). If unset, matches hero above.
# NEXT_PUBLIC_OG_IMAGE="/images/lumpia.jpg"
# Optional: culture/FAQ page decorative corner (defaults to /images/pancit.jpg).
# NEXT_PUBLIC_CULTURE_DECOR_IMAGE="https://images.unsplash.com/photo-…"
