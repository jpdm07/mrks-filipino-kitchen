{
  "name": "mrks-filipino-kitchen",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "dev:clean": "node -e \"try{require('fs').rmSync('.next',{recursive:true,force:true})}catch(e){}\" && next dev -p 3000",
    "dev:lan": "next dev -H 0.0.0.0 -p 3000",
    "build": "node scripts/build-production.mjs",
    "start": "next start -H 0.0.0.0 -p 3000",
    "lint": "next lint",
    "postinstall": "node scripts/postinstall-prisma.mjs",
    "db:generate": "node scripts/prisma-generate.mjs",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "bootstrap:availability": "tsx scripts/bootstrap-availability.ts",
    "availability:month-biweekly": "tsx scripts/set-current-month-biweekly-availability.ts",
    "setup:local": "node scripts/prisma-generate.mjs && npx prisma migrate deploy && npx prisma db seed && npx tsx scripts/bootstrap-availability.ts",
    "db:studio": "prisma studio",
    "deploy:vercel": "npx vercel --prod",
    "env:vercel": "node scripts/sync-env-to-vercel.mjs",
    "env:vercel:all": "node scripts/sync-env-to-vercel.mjs --preview"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "5.22.0",
    "@react-pdf/renderer": "^4.4.1",
    "framer-motion": "^12.38.0",
    "googleapis": "^144.0.0",
    "lucide-react": "^1.8.0",
    "next": "14.2.35",
    "nodemailer": "^8.0.5",
    "prisma": "5.22.0",
    "qrcode": "^1.5.4",
    "react": "^18",
    "react-dom": "^18",
    "simple-icons": "^16.16.0",
    "twilio": "^5.13.1"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "dotenv": "^16.6.1",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
