generator client {
  provider      = "prisma-client-js"
  // Windows dev: avoid Node-API .dll issues. Vercel/Linux: ship the RHEL engine too.
  engineType    = "binary"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Admin kitchen recipes — scalable batch formulas (JSON); never exposed on public menu routes by default.
model Recipe {
  id           String   @id @default(cuid())
  name         String
  category     String
  baseServings Int
  ingredients  Json
  instructions Json
  notes        String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Order {
  id               String   @id @default(cuid())
  orderNumber      String   @unique
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  customerName     String
  phone            String
  email            String
  items            String
  subtotal         Float
  tax              Float
  total            Float
  pickupDate       String?
  pickupTime       String?
  /// Admin/manual: free-text pickup window shown verbatim when set (overrides date/time slots).
  customPickupTime String?
  notes            String?
  wantsUtensils    Boolean  @default(false)
  utensilSets      Int      @default(0)
  utensilCharge    Float    @default(0.0)
  wantsRecurring   Boolean  @default(false)
  customInquiry    String?
  status           String   @default("Pending Payment Verification")
  paymentMethod    String?
  paymentStatus    String?
  adminNotes       String?
  subscribeUpdates Boolean  @default(false)
  /// Customer asked for a printed receipt packed with pickup order.
  wantsPrintedReceipt Boolean @default(false)
  // Test / practice: excluded from finances; deletable in admin.
  isDemo             Boolean  @default(false)
  /// JSON array of refund ledger entries (admin-recorded; funds returned outside the app via Venmo/Zelle/etc.).
  refundLog          String?
  /// True when the order was entered in admin (walk-in / phone) rather than website checkout.
  manualEntry        Boolean  @default(false)
  /// Optional: actual cash/card amount collected (vs order total) for your records.
  amountReceivedUsd  Float?
  /// Gratuity you recorded for this order.
  tipAmount          Float    @default(0)
  /// Internal notes on payment/tip adjustments (why numbers differ).
  paymentRecordNotes String?
  inventoryDeductionLogs InventoryDeductionLog[]
}

model Availability {
  id        String   @id @default(cuid())
  date      String   @unique
  isOpen    Boolean  @default(false)
  slots     String   @default("[]")
  note      String?
  updatedAt DateTime @default(now()) @updatedAt
}

/// Stock units for admin-controlled availability, banners, and inventory-linked pickup slots.
model InventoryItem {
  id                 Int      @id @default(autoincrement())
  menuItemId         String?
  itemName           String
  unitLabel          String
  quantityInStock    Int      @default(0)
  isAvailable        Boolean  @default(false)
  showBanner         Boolean  @default(false)
  bannerMessage      String?
  lowStockThreshold  Int?
  /// How checkout lines map to `quantityInStock`: `order_line_qty` (sum line qty for linked menu SKU), or `lumpia_frozen_dozen` (frozen lumpia sizes → dozens).
  deductionMode      String   @default("order_line_qty")
  updatedAt          DateTime @updatedAt
  menuItem           MenuItem? @relation(fields: [menuItemId], references: [id], onDelete: SetNull)
  pickupSlots        InventoryPickupSlot[]
  deductionLogs      InventoryDeductionLog[]
}

/// Admin-opened pickup windows tied to an inventory item (capacity + auto-close).
model InventoryPickupSlot {
  id                Int      @id @default(autoincrement())
  inventoryItemId   Int
  dateYmd           String
  slotLabelsJson    String   @default("[]")
  maxOrders         Int
  ordersFilled      Int      @default(0)
  autoCloseWhenZero Boolean  @default(true)
  closed            Boolean  @default(false)
  inventoryItem     InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)

  @@index([dateYmd])
  @@index([inventoryItemId])
}

model InventoryDeductionLog {
  id               Int      @id @default(autoincrement())
  inventoryItemId  Int
  orderId          String
  quantityDeducted Int
  wasManualEntry   Boolean
  note             String?
  createdAt        DateTime @default(now())
  inventoryItem    InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  order            Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([inventoryItemId])
  @@index([orderId])
}

model MenuItem {
  id                 String  @id @default(cuid())
  name               String
  description        String
  category           String
  calories           String
  basePrice          Float
  sizes              String
  photoUrl           String
  isActive           Boolean @default(true)
  soldOut            Boolean @default(false)
  stockNotes         String?
  hasCooked          Boolean @default(false)
  hasFrozen          Boolean @default(false)
  sortOrder          Int     @default(0)
  /// Minutes of Friday cook time for one unit of this line (sizeKey in capacity map); 0 for flan.
  cookMinutes        Int     @default(0)
  /// True only for Caramel Flan — used for pickup calendar + weekly flan cap (24/week).
  isFlanItem         Boolean @default(false)
  // Same variantGroup = one menu card; each DB row stays a separate cart line.
  variantGroup       String?
  variantShortLabel  String?
  groupCardTitle     String?
  groupServingBlurb  String?
  inventoryItems     InventoryItem[]
}

/// Singleton row: manual “week sold out” override (current week only; ignored when week changes).
model KitchenCapacitySettings {
  id String @id @default("default")
  /// Monday YYYY-MM-DD of the week admin force-closed; must match current week to apply
  manualSoldOutWeekStart String?
}

model Subscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
}

model Suggestion {
  id       String  @id @default(cuid())
  option   String
  count    Int     @default(0)
  isCustom Boolean @default(false)
}

model DishSuggestionSubmission {
  id          String   @id @default(cuid())
  text        String
  submittedAt DateTime @default(now())
  ipAddress   String?
}

model Expense {
  id          String   @id @default(cuid())
  date        String
  store       String
  category    String
  description String
  amount      Float
  receiptUrl  String?
  receiptData String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  isEdited    Boolean  @default(false)
}

model Inquiry {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String
  subject   String
  message   String
  createdAt DateTime @default(now())
  isRead    Boolean  @default(false)
}

/// Business vehicle miles for tax records (e.g. ingredient runs, occasional delivery).
model TaxMileageLog {
  id        String   @id @default(cuid())
  date      String
  miles     Float
  purpose   String
  routeFrom String?
  routeTo   String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Other items to document for taxes (equipment, fees, home office %, etc.).
model TaxSupportingEntry {
  id          String   @id @default(cuid())
  date        String
  category    String
  title       String
  description String?
  amount      Float?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model OrderCounter {
  id    String @id @default("counter")
  count Int    @default(1000)
}

model PricingSettings {
  id            String @id @default("default")
  sampleLumpia  Float  @default(4.33)
  sampleQuail   Float  @default(2.49)
  sampleFlan    Float  @default(3.5)
  samplePancit  Float  @default(6.3)
  /// Admin: force scheduling banner State A even when same-day inventory rows exist.
  schedulingBannerForceStateA Boolean @default(false)
}

/// Admin prep checklist overrides for a pickup week (anchored by Thursday YMD, Sun–Sat week).
model PrepSummaryWeekState {
  id              String   @id @default(cuid())
  weekThursdayYmd String   @unique
  stateJson       String   @default("{}")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

/// One row per week: automatic prep-summary email already sent (avoids duplicates on cron retry).
model PrepSummaryEmailLog {
  id              String   @id @default(cuid())
  weekThursdayYmd String   @unique
  sentAt          DateTime @default(now())
}
